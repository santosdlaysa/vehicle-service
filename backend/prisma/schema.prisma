generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceStatus {
  AGUARDANDO_COLETA
  EM_TRANSITO_PARA_ESTETICA
  RECEBIDO_NA_ESTETICA
  EM_LAVAGEM_SERVICO
  PRONTO_PARA_DEVOLUCAO
  EM_TRANSITO_PARA_ENTREGA
  ENTREGUE_CONCLUIDO
}

enum MediaType {
  ENTRY
  EXIT
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  services      Service[]       @relation("CreatedBy")
  uploadedMedia ServiceMedia[]
  statusChanges StatusHistory[]

  @@map("users")
}

model Customer {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  services Service[]

  @@map("customers")
}

model Service {
  id                 String        @id @default(uuid())
  customerName       String        @map("customer_name")
  customerPhone      String        @map("customer_phone")
  vehicleModel       String        @map("vehicle_model")
  vehiclePlate       String        @map("vehicle_plate")
  vehicleColor       String        @map("vehicle_color")
  status             ServiceStatus @default(AGUARDANDO_COLETA)
  description        String?
  preferredDate      DateTime?     @map("preferred_date")
  pickupAddress      String?       @map("pickup_address")
  deliveryAddress    String?       @map("delivery_address")
  driverName         String?       @map("driver_name")
  linkSharedAt       DateTime?     @map("link_shared_at")
  deliveredAt        DateTime?     @map("delivered_at")
  receiptConfirmedAt DateTime?     @map("receipt_confirmed_at")
  createdBy          String?       @map("created_by")
  customerId         String?       @map("customer_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  creator       User?           @relation("CreatedBy", fields: [createdBy], references: [id])
  customer      Customer?       @relation(fields: [customerId], references: [id])
  checklists    Checklist[]
  media         ServiceMedia[]
  statusHistory StatusHistory[]

  @@map("services")
}

enum ChecklistType {
  PICKUP
  DELIVERY
}

model Checklist {
  id               String        @id @default(uuid())
  serviceId        String        @map("service_id")
  type             ChecklistType @default(PICKUP)
  scratches        Boolean       @default(false)
  dents            Boolean       @default(false)
  mirrorsOk        Boolean       @default(true) @map("mirrors_ok")
  lightsOk         Boolean       @default(true) @map("lights_ok")
  tiresOk          Boolean       @default(true) @map("tires_ok")
  glassOk          Boolean       @default(true) @map("glass_ok")
  internalObjects  String?       @map("internal_objects")
  fuelLevel        String        @default("1/2") @map("fuel_level")
  odometer         Int?
  odometerPhotoUrl String?       @map("odometer_photo_url")
  notes            String?
  isLocked         Boolean       @default(false) @map("is_locked")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, type])
  @@map("checklists")
}

model ServiceMedia {
  id         String    @id @default(uuid())
  serviceId  String    @map("service_id")
  url        String
  type       MediaType
  uploadedBy String    @map("uploaded_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  service  Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploadedBy], references: [id])

  @@map("service_media")
}

model StatusHistory {
  id        String         @id @default(uuid())
  serviceId String         @map("service_id")
  oldStatus ServiceStatus? @map("old_status")
  newStatus ServiceStatus  @map("new_status")
  changedBy String?        @map("changed_by")
  changedAt DateTime       @default(now()) @map("changed_at")

  service       Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  changedByUser User?   @relation(fields: [changedBy], references: [id])

  @@map("status_history")
}
